# kratos-demo 环境变量模板
# 用法：复制为 .env 并填入真实值（.env 已 gitignore，不入库）
#   cp .env.example .env
#
# MySQL DSN（明文密码仅存于本地 .env，不入版本库）
# 注意：Ubuntu/WSL MySQL 默认 root@localhost 用 auth_socket（仅 socket 免密），
#       TCP 连接需先改为密码认证：
#       ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY '你的密码';
DATABASE_SOURCE=root:yourpassword@tcp(127.0.0.1:3306)/kratos_demo
